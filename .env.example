# =============================================================================
# AI-Powered Leaflet Data Extraction Platform
# Environment Configuration
# =============================================================================

# Application Settings
APP_NAME=leaflet-extraction-platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true

# Security Settings (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# Database Settings (PostgreSQL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=leaflet_user
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=leaflet_extraction
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password
REDIS_DB=0
CACHE_TTL_DEFAULT=3600
CACHE_TTL_LEAFLET=86400

# Celery Settings
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=4

# Storage Settings (local/s3)
STORAGE_MODE=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=leaflet-extraction-storage
LOCAL_STORAGE_PATH=./storage

# -----------------------------------------------------------------------------
# File Processing Settings
# -----------------------------------------------------------------------------
# Maximum file size (bytes) - 100MB
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=.pdf
PDF_DPI=300
PDF_OUTPUT_FORMAT=PNG
PDF_MAX_PAGES=100

# -----------------------------------------------------------------------------
# Default Region Settings (Balkans/Adriatic)
# -----------------------------------------------------------------------------
# Default currency (EUR for Slovenia/Croatia, RSD for Serbia)
DEFAULT_CURRENCY=EUR

# Default language (auto for auto-detection, or specific: sl, hr, sr, en, etc.)
DEFAULT_LANGUAGE=auto

# Default country code (SI=Slovenia, HR=Croatia, RS=Serbia, BA=Bosnia)
DEFAULT_COUNTRY=SI

# Supported currencies (comma-separated)
SUPPORTED_CURRENCIES=EUR,RSD,HRK,BAM,MKD,ALL

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=sl,hr,sr,bs,mk,sq,en,de,it

# -----------------------------------------------------------------------------
# Image Processing Settings
# -----------------------------------------------------------------------------
IMAGE_QUALITY_HIGH=95
IMAGE_QUALITY_MEDIUM=85
IMAGE_QUALITY_LOW=60
BASE64_SIZE_THRESHOLD=102400

# -----------------------------------------------------------------------------
# Processing Queue Settings
# -----------------------------------------------------------------------------
PDF_BATCH_SIZE=6
VLM_BATCH_SIZE=6
IMAGE_BATCH_SIZE=10
PDF_PROCESSING_TIMEOUT=300
VLM_EXTRACTION_TIMEOUT=120
IMAGE_EXTRACTION_TIMEOUT=60

# -----------------------------------------------------------------------------
# Validation Settings
# -----------------------------------------------------------------------------
CONFIDENCE_HIGH=0.90
CONFIDENCE_MEDIUM=0.75
CONFIDENCE_LOW=0.50
AUTO_APPROVAL_THRESHOLD=0.90
MAX_PRICE=1000000
MIN_PRICE=0.01

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Email Settings (SMTP)
# -----------------------------------------------------------------------------
# Enable email sending (set to false for local development without email)
SMTP_ENABLED=false

# SMTP server configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USE_TLS=true

# SMTP authentication (leave empty if no auth required)
SMTP_USER=
SMTP_PASSWORD=

# Email sender details
SMTP_FROM_EMAIL=info@leafxtract.com
SMTP_FROM_NAME=Leaflet Extraction Platform

# Support/contact email (receives contact form submissions and registration alerts)
SUPPORT_EMAIL=info@leafxtract.com

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000